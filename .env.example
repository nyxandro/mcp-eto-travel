# Copy this file to .env and replace the sample values with your own domain.

# MCP transport mode. Keep "http" for self-hosted remote deployments.
TRANSPORT_MODE=http

# Container bind host and port.
HOST=0.0.0.0
PORT=3000

# MCP HTTP endpoint path.
MCP_PATH=/mcp

# Comma-separated list of allowed Host headers.
# Replace mcp.example.com with your real public domain.
ALLOWED_HOSTS=mcp.example.com,localhost,127.0.0.1

# Public domain example for your reverse proxy.
PUBLIC_DOMAIN=mcp.example.com
